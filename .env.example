# Copy to .env at repo root:  cp .env.example .env
# Used by docker-compose.yml

# Required for production — gateway and auth must use the same value.
# Leave unset for local/docker testing (both services share the same built-in default).
JWT_SECRET=

# Optional — AI service (leave empty to use local fallback mode)
GEMINI_API_KEY=
GROQ_API_KEY=
