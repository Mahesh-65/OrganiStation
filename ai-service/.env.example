# Copy to .env:  cp .env.example .env
#
# IMPORTANT: Put your API key here — NOT in the Dockerfile and NOT at docker build time.
# The key is read when the container STARTS (runtime), via --env-file or Container Apps secrets.

PORT=8000
HOST=0.0.0.0

CHROMA_DB_PATH=./chroma_db

# Gemini (embeddings + chat) — https://aistudio.google.com/
GEMINI_API_KEY=

# Optional: Groq (Llama chat) — https://console.groq.com/
# Use one or both. If neither is set, the service runs with local fallback (limited).
GROQ_API_KEY=

# Docker: CHROMA_DB_PATH=/data/chroma_db  (mount a volume at /data)

# Future Azure AI Foundry (production — managed identity, no API keys):
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_CHAT_DEPLOYMENT=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_INDEX=
