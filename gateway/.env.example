# Copy to .env:  cp .env.example .env
# Gateway reads this file on startup (dotenv). Do NOT bake into the Docker image.

PORT=3000

# Must match auth-service JWT_SECRET exactly
JWT_SECRET=change-this-to-a-strong-shared-secret

# Local development (services on host machine)
AUTH_SERVICE_URL=http://localhost:8001
AI_SERVICE_URL=http://localhost:8000
HR_SERVICE_URL=http://localhost:8002
PROJECT_SERVICE_URL=http://localhost:8003
FINANCE_SERVICE_URL=http://localhost:8004

# Docker Compose / Container Apps: use service names instead of localhost, e.g.
# AUTH_SERVICE_URL=http://auth:8001
